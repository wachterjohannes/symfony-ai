{
    "name": "symfony/ai-doctrine-store",
    "description": "Doctrine ORM entity loader for Symfony AI Store, turning entities into RAG documents",
    "license": "MIT",
    "type": "symfony-ai-store",
    "keywords": [
        "ai",
        "bridge",
        "doctrine",
        "orm",
        "rag",
        "store"
    ],
    "authors": [
        {
            "name": "Johannes Wachter",
            "email": "johannes@sulu.io"
        },
        {
            "name": "Symfony Community",
            "homepage": "https://symfony.com/contributors"
        }
    ],
    "require": {
        "php": ">=8.2",
        "doctrine/event-manager": "^1.2|^2.0",
        "doctrine/orm": "^2.14|^3.0",
        "doctrine/persistence": "^2.4|^3.1",
        "symfony/ai-store": "^0.10",
        "symfony/property-access": "^7.3|^8.0",
        "symfony/uid": "^7.3|^8.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpunit/phpunit": "^11.5.53"
    },
    "minimum-stability": "dev",
    "autoload": {
        "psr-4": {
            "Symfony\\AI\\Store\\Bridge\\Doctrine\\": ""
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Symfony\\AI\\PHPStan\\": "../../../../../.phpstan/",
            "Symfony\\AI\\Store\\Bridge\\Doctrine\\Tests\\": "Tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "thanks": {
            "name": "symfony/ai",
            "url": "https://github.com/symfony/ai"
        }
    }
}
